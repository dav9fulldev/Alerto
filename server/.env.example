# ALERTO Environment Configuration
# Copy this file to .env and fill in your values

# ============ DATABASE ============
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/alerto?retryWrites=true&w=majority
MONGO_DB_NAME=alerto

# ============ NSFW DETECTION ============
# Enable/disable NSFW content moderation
NSFW_ENABLED=true

# NSFW scoring thresholds
# NSFW_THRESHOLD: Flag for review (default: 0.7)
# NSFW_BLOCK_THRESHOLD: Reject image (default: 0.85)
NSFW_THRESHOLD=0.7
NSFW_BLOCK_THRESHOLD=0.85

# Use online moderation API (optional fallback)
USE_ONLINE_MODERATION=false

# Automatically blur NSFW images
BLUR_NSFW_IMAGES=true

# Directory to store NSFW detection logs
NSFW_LOG_DIR=uploads/nsfw_logs

# Optional: OpenAI API key for online moderation
OPENAI_API_KEY=sk-your-openai-api-key

# ============ FILE UPLOAD ============
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# ============ TRANSLATION ============
GOOGLE_TRANSLATE_ENABLED=true

# ============ LOGGING ============
LOG_LEVEL=INFO
